{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$CLAUDE_PROJECT_DIR\"/gradlew ] && \"$CLAUDE_PROJECT_DIR\"/gradlew spotlessApply --quiet -p \"$CLAUDE_PROJECT_DIR\" 2>&1 | tail -5 || true"
          }
        ]
      }
    ]
  }
}
